# Local secrets (not committed). Copy to ".env.local" in the project root.
# Restart `npm run dev` after changing this file.
fmpApiKey=

# Supabase (optional): Screener tab reads with anon key; nightly job needs service role + URL.
# Client bundle: use VITE_* names, or SUPABASE_URL + SUPABASE_ANON_KEY (Vercel-friendly; mapped at build).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Never expose the service role to the browser — GitHub Actions / server only.
SUPABASE_SERVICE_ROLE_KEY=

# Home page: when Supabase URL+anon are set, the app calls `home-fmp-cache` Edge (Postgres TTL) unless disabled.
# Set to false to always use browser FMP only (no Edge / no ticker_fmp_home_cache writes).
VITE_HOME_FMP_CACHE=

# Nightly batch (optional): cap universe size, throttle FMP (ms between tickers), page through universe.
SCREEN_MAX_TICKERS=50
SCREEN_OFFSET=0
SCREEN_TICKER_GAP_MS=30000
SCREEN_EARNINGS_GAP_MS=3000
SCREEN_FETCH_PEERS=

# Material news pipeline (npm run news:pipeline / GitHub Actions news-pipeline.yml).
GEMINI_API_KEY=
# SEC_USER_AGENT=StockMoat/1.0 (contact: you@email.com)
# NEWS_FMP_GAP_MS=400
# NEWS_SEC_GAP_MS=280

# Nightly planner (default): merge FMP trending movers + DB staleness + home cache + core screener slice.
# NIGHTLY_MODE=legacy → only SCREEN_MAX_TICKERS/SCREEN_OFFSET slice (previous behavior).
NIGHTLY_MODE=
NIGHTLY_BUDGET=1000
NIGHTLY_STALE_DAYS=14
NIGHTLY_TRENDING_LIMIT=100
NIGHTLY_TRENDING_PER_LIST=45
