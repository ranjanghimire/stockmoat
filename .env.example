# Local secrets (not committed). Copy to ".env.local" in the project root.
# Restart `npm run dev` after changing this file.
fmpApiKey=

# Supabase (optional): Screener tab reads with anon key; nightly job needs service role + URL.
# Client bundle: use VITE_* names, or SUPABASE_URL + SUPABASE_ANON_KEY (Vercel-friendly; mapped at build).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Never expose the service role to the browser — GitHub Actions / server only.
SUPABASE_SERVICE_ROLE_KEY=

# Home page: when true and Supabase is configured, load FMP company pack via `home-fmp-cache` Edge Function
# (Postgres-backed TTL: 72h pack, 60m quote, 30d peer medians). Deploy migration + function; set Edge secret FMP_API_KEY.
VITE_HOME_FMP_CACHE=false

# Nightly batch (optional): cap universe size, throttle FMP (ms between tickers), page through universe.
SCREEN_MAX_TICKERS=50
SCREEN_OFFSET=0
SCREEN_TICKER_GAP_MS=30000
SCREEN_FETCH_PEERS=
