{
  "name": "stockmoat",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "screen:nightly": "vite-node src/scripts/nightly-screen.ts",
    "screen:charts": "vite-node src/scripts/nightly-screen-charts.ts",
    "sync:edge-fmp-shared": "mkdir -p supabase/functions/home-fmp-cache/_shared && cp src/lib/fmp/normalize.ts supabase/functions/home-fmp-cache/_shared/normalize.ts && cp src/lib/fmp/profileClassification.ts supabase/functions/home-fmp-cache/_shared/profileClassification.ts && cp src/lib/fmp/fetchCompanyRawPack.ts supabase/functions/home-fmp-cache/_shared/fetchCompanyRawPack.ts && cp src/lib/fmp/peerMedians.ts supabase/functions/home-fmp-cache/_shared/peerMedians.ts && node scripts/patch-edge-shared-imports.mjs",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.86.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.9.6",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.2.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-node": "^6.0.0",
    "vitest": "^3.2.4",
    "yahoo-finance2": "^2.13.3"
  }
}
